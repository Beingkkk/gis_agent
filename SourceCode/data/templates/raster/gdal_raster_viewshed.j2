{# @id gdal_raster_viewshed #}
{# @name 视域分析 #}
{# @description 基于数字高程模型计算观察者可视区域的栅格分析工具 #}
{# @concept "视域分析基于Wang2000算法，从指定观察点计算DEM中每个像元相对于观察者的可见性" #}
{# @concept "输出栅格为Byte类型，像素值表示可见性状态（可见/不可见/可能可见/超出范围）" #}
{# @note 观察者位置可通过-X -Y单独指定，或用-position一次性指定X,Y或X,Y,H三种格式 #}
{# @note 当mode设为DEM或ground时，输出栅格为Float64类型，表示最小可见高程或地面高程 #}
{# @seealso gdal_raster_pipeline #}
{# @common_error "Failed to open datasource" — 输入DEM文件路径不存在、文件损坏或格式不支持，GDAL无法打开数据源 #}
{# @common_error "Point outside DEM extent" — 观察者坐标(X,Y)超出DEM栅格的有效范围 #}
{# @param input file_path required 输入栅格数据集（通常为DEM高程数据） #}
{# @param output file_path required 输出栅格数据集（视域分析结果） #}
{# @param position string required 观察者位置坐标，格式为 X,Y 或 X,Y,H（包含观察者高度） #}
{# @param height float optional 观察者相对于地面的高度（单位与DEM一致） #}
{# @param target_height float optional 目标物相对于DEM表面的高度（默认0） #}
{# @param mode string optional 输出模式：normal（可见/不可见二值）、DEM（输出高程值）、ground（地面高程）、cumulative（累积可见性计数） default=normal #}
{# @param max_distance float optional 最大可视距离，用于限制计算范围和输出栅格范围 #}
{# @param band integer optional 输入栅格使用的波段序号（从1开始） default=1 #}
{# @param visible_value integer optional 可见区域的像素值（默认255） default=255 #}
{# @param invisible_value integer optional 不可见区域的像素值（默认0） #}
{# @param of string optional 输出格式名称，如 GTiff、COG 等 #}
{# @param overwrite boolean optional 是否覆盖已存在的输出文件 #}
{# @param curvature_coefficient float optional 考虑地球曲率和大气折射效应的系数 #}
{# @param observer_spacing integer optional 多个观察者之间的像元间距（用于生成多点视域） default=10 #}
{# @param num_threads string optional 并行计算的线程数或 ALL_CPUS default=3 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_raster_viewshed

gdal raster viewshed{% if of %} -f {{ of | quote }}{% endif %}{% if overwrite %} --overwrite{% endif %}{% if position %} -p {{ position | quote }}{% endif %}{% if height %} -z {{ height }}{% endif %}{% if target_height %} --target-height {{ target_height }}{% endif %}{% if mode %} --mode {{ mode | quote }}{% endif %}{% if max_distance %} --max-distance {{ max_distance }}{% endif %}{% if band %} -b {{ band }}{% endif %}{% if visible_value %} --visible-value {{ visible_value }}{% endif %}{% if invisible_value %} --invisible-value {{ invisible_value }}{% endif %}{% if curvature_coefficient %} --curvature-coefficient {{ curvature_coefficient }}{% endif %}{% if observer_spacing %} --observer-spacing {{ observer_spacing }}{% endif %}{% if num_threads %} -j {{ num_threads | quote }}{% endif %} {{ input | safe_path | quote }} {{ output | safe_path | quote }}

