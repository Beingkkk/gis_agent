{# @id reproject #}
{# @name 矢量重投影 #}
{# @description 将矢量数据重投影到指定坐标系 #}
{# @concept "重投影" — 将数据从一个坐标参考系转换到另一个坐标参考系 #}
{# @concept "EPSG" — 欧洲石油调查组织制定的坐标系编码标准，如 EPSG:4326（WGS84） #}
{# @note ogr2ogr 会自动处理重投影，源数据的坐标系从文件元数据读取 #}
{# @seealso raster/warp_reproject — 栅格数据重投影 #}
{# @common_error "Failed to process SRS" — 坐标系代码无效，检查 EPSG 编号是否正确 #}
{# @param input file_path required 输入矢量文件路径 #}
{# @param output file_path required 输出矢量文件路径 #}
{# @param t_srs crs required 目标坐标系 EPSG 代码 #}

@echo off
REM Generated by GIS Agent
REM Template: reproject

ogr2ogr -f "ESRI Shapefile" {{ output | safe_path | quote }} {{ input | safe_path | quote }} -t_srs {{ t_srs | quote }}

REM Done
