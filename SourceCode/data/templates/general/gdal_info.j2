{# @id gdal_info #}
{# @name 数据集信息查询 #}
{# @description 查询栅格或矢量数据集的元信息、坐标系统、空间范围、波段统计等详细信息 #}
{# @concept "gdal info 是 GDAL 的数据集信息查看工具，可自动识别输入数据类型（栅格、矢量或多维栅格）并返回相应的元信息" #}
{# @concept "栅格数据会显示波段数、分辨率、坐标系统、仿射变换参数、统计值等；矢量数据会显示图层结构、要素数量、字段定义等" #}
{# @note 不指定输出格式时默认返回 JSON 格式，便于程序解析和处理 #}
{# @note 对于复杂数据集，可使用 --config 选项设置特定的 GDAL 配置来控制输出行为 #}
{# @common_error "Unable to open datasource" — 输入文件路径不存在、文件损坏或指定的格式不受 GDAL 支持 #}
{# @common_error "Permission denied" — 对输入文件没有读取权限，可能需要检查文件访问权限设置 #}
{# @param input file_path required 输入的栅格、矢量或多维栅格数据集路径 #}
{# @param of string optional 输出格式，支持 json（默认）或 text #}
{# @param config string optional 设置 GDAL 配置选项，格式为 KEY=VALUE #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_info

gdal info{% if of %} -of {{ of | quote }}{% endif %}{% if config %} --config {{ config | quote }}{% endif %} {{ input | safe_path | quote }}

