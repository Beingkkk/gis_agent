{# @id raster_scale #}
{# @name 栅格像元值缩放 #}
{# @description 将栅格数据的像元值从指定范围线性或非线性缩放到新范围，常用于数据归一化 #}
{# @concept "线性缩放将像素值从[input_min, input_max]区间映射到[output_min, output_max]区间" #}
{# @concept "exponent参数支持幂函数非线性缩放，公式为output = (normalized_input)^exponent * (output_max - output_min) + output_min" #}
{# @note 如果不指定输入范围，程序会自动从源数据计算；如果不指定输出范围，整数类型默认0到类型最大值（如Byte为255），浮点类型默认0到1 #}
{# @seealso raster_unscale #}
{# @common_error "--input-min requires --input-max / --input-max requires --input-min" — input_min和input_max必须同时指定或同时省略，output_min和output_max同理 #}
{# @common_error "Scale could not be computed" — 源数据为空或所有像素值相同导致无法计算缩放范围，可使用--input-min和--input-max手动指定范围 #}
{# @param input file_path required 输入栅格数据集路径 #}
{# @param output file_path required 输出栅格数据集路径 #}
{# @param input_min float optional 源数据范围最小值（需与input_max同时使用） #}
{# @param input_max float optional 源数据范围最大值（需与input_min同时使用） #}
{# @param output_min float optional 目标范围最小值（需与output_max同时使用） #}
{# @param output_max float optional 目标范围最大值（需与output_min同时使用） #}
{# @param exponent float optional 非线性缩放的指数（幂函数），默认为1即线性缩放 #}
{# @param output_data_type string optional 输出数据类型，如Byte、Int16、UInt32、Float32等 #}
{# @param output_format string optional 输出格式名称，如GTiff、COG等 #}
{# @param band integer optional 指定要缩放的波段编号（从1开始），不指定则对所有波段应用缩放 #}
{# @param no_clip boolean optional 不裁剪超出源范围的输入值，默认会裁剪 #}
{# @param overwrite boolean optional 允许覆盖已存在的输出文件 #}

@echo off
REM Generated by GIS Agent
REM Template: raster_scale

gdal raster scale{% if input_min and input_max %} --input-min {{ input_min }} --input-max {{ input_max }}{% endif %}{% if output_min and output_max %} --output-min {{ output_min }} --output-max {{ output_max }}{% endif %}{% if exponent %} --exponent {{ exponent }}{% endif %}{% if no_clip %} --no-clip{% endif %}{% if output_format %} --format {{ output_format | quote }}{% endif %}{% if output_data_type %} --output-data-type {{ output_data_type | quote }}{% endif %}{% if band %} --band {{ band }}{% endif %}{% if overwrite %} --overwrite{% endif %} {{ input | safe_path | quote }} {{ output | safe_path | quote }}

REM Done
