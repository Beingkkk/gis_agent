{# @id gdaltransform #}
{# @name 坐标投影转换 #}
{# @description 将单个或批量坐标从一个坐标系转换到另一个坐标系，支持多种投影转换方式 #}
{# @concept "gdaltransform是GDAL的坐标转换工具，可将地理坐标、投影坐标在不同坐标系之间转换，支持EPSG编码、PROJ.4字符串、WKT格式等多种SRS定义" #}
{# @concept "该工具支持基于GCP（地面控制点）的多项式和薄板样条变换、RPC模型转换以及地理定位数组转换等多种高级转换方式" #}
{# @note 坐标从标准输入读取，每行一组坐标（X Y或X Y Z），结果输出到标准输出 #}
{# @note 对于动态坐标系（动态参考框架），可使用-s_coord_epoch和-t_coord_epoch指定坐标历元 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Attempt to transform point without bidirectional transform" — 源坐标系或目标坐标系定义不完整，缺少必要的投影信息导致无法建立转换关系 #}
{# @common_error " Too few points to compute transformation" — 使用GCP转换时提供的地面控制点不足，通常需要至少3个GCP点 #}
{# @param srcfile file_path optional 源栅格数据集路径，用于读取源坐标系定义（GCP转换时使用） #}
{# @param s_srs crs optional 源空间参考系统定义，支持EPSG编号、PROJ.4字符串或.prj文件路径 #}
{# @param t_srs crs optional 目标空间参考系统定义，用于定义输出坐标系 #}
{# @param ct string optional 自定义坐标操作定义（PROJ字符串、WKT2或EPSG URN），覆盖默认转换方法 #}
{# @param order integer optional 多项式纠正阶数（1-3），不指定则自动选择 #}
{# @param tps boolean optional 强制使用薄板样条转换器进行GCP变换 #}
{# @param rpc boolean optional 强制使用RPC（有理多项式系数）进行转换 #}
{# @param geoloc boolean optional 强制使用地理定位数组进行转换 #}
{# @param i boolean optional 反向转换模式，从目标坐标系转换到源坐标系 #}
{# @param output_xy boolean optional 仅输出X Y坐标，忽略Z值 #}
{# @param E boolean optional 回显模式，在输出行前附加输入坐标 #}
{# @param field_sep string optional 输出字段分隔符，默认为空格 default=  #}
{# @param ignore_extra_input boolean optional 忽略输入行末尾的非数字内容并附加到输出 #}

@echo off
REM Generated by GIS Agent
REM Template: gdaltransform

gdaltransform{% if s_srs %} -s_srs {{ s_srs | quote }}{% endif %}{% if t_srs %} -t_srs {{ t_srs | quote }}{% endif %}{% if ct %} -ct {{ ct | quote }}{% endif %}{% if order %} -order {{ order }}{% endif %}{% if tps %} -tps{% endif %}{% if rpc %} -rpc{% endif %}{% if geoloc %} -geoloc{% endif %}{% if i %} -i{% endif %}{% if output_xy %} -output_xy{% endif %}{% if E %} -E{% endif %}{% if field_sep %} -field_sep {{ field_sep | quote }}{% endif %}{% if ignore_extra_input %} -ignore_extra_input{% endif %}{% if srcfile %} {{ srcfile | safe_path | quote }}{% endif %}

