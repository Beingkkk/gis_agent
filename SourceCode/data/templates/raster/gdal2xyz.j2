{# @id gdal2xyz #}
{# @name 栅格转XYZ点云 #}
{# @description 将栅格数据转换为XYZ格式的文本点云数据 #}
{# @concept "gdal2xyz是GDAL的栅格转XYZ工具，将栅格像素转换为X Y Z（列 行 值）格式的文本点云数据" #}
{# @concept "默认输出使用空格分隔，支持选择多波段、设置空间裁剪窗口、跳过或替换nodata值等功能" #}
{# @note gdal2xyz是Python工具，需要GDAL Python绑定支持才能使用 #}
{# @note XYZ输出格式为文本形式，每行包含X坐标、Y坐标和像素值，适用于点云分析或导入其他GIS软件 #}
{# @seealso gdal_translate_xyz #}
{# @common_error "Unable to open dataset" — 输入栅格文件路径不存在、文件格式不支持或文件损坏 #}
{# @common_error "The -srcwin option expects 4 values" — 空间裁剪窗口参数不完整，需要同时提供xoff、yoff、xsize、ysize四个值 #}
{# @param src_dataset file_path required 输入栅格文件路径，支持文件路径、数据源URL或子数据集名称 #}
{# @param dst_dataset file_path required 输出XYZ文本文件路径 #}
{# @param band integer optional 选择输出波段编号（从1开始），未指定时默认选择第一个波段 #}
{# @param allbands boolean optional 输出所有输入波段，取代手动指定单个波段 #}
{# @param skip integer optional 每个迭代中跳过的行/列数，用于降低输出点密度 #}
{# @param srcwin_xoff integer optional 基于像素/行位置裁剪的起始列偏移量（与yoff、xsize、ysize配合使用） #}
{# @param srcwin_yoff integer optional 基于像素/行位置裁剪的起始行偏移量 #}
{# @param srcwin_xsize integer optional 裁剪窗口的列数（宽度） #}
{# @param srcwin_ysize integer optional 裁剪窗口的行数（高度） #}
{# @param csv boolean optional 使用逗号作为分隔符替代默认的空格分隔符 #}
{# @param skipnodata boolean optional 排除输出中值为nodata的行 #}
{# @param srcnodata string optional 指定源数据的nodata值，用于跳过或替换操作 #}
{# @param dstnodata string optional 将源nodata值替换为指定的新nodata值 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal2xyz

gdal2xyz{% if allbands %} -allbands{% endif %}{% if band %} -b {{ band }}{% endif %}{% if skip %} -skip {{ skip }}{% endif %}{% if srcwin_xoff and srcwin_yoff and srcwin_xsize and srcwin_ysize %} -srcwin {{ srcwin_xoff }} {{ srcwin_yoff }} {{ srcwin_xsize }} {{ srcwin_ysize }}{% endif %}{% if csv %} -csv{% endif %}{% if skipnodata %} -skipnodata{% endif %}{% if srcnodata %} -srcnodata {{ srcnodata | quote }}{% endif %}{% if dstnodata %} -dstnodata {{ dstnodata | quote }}{% endif %} {{ src_dataset | safe_path | quote }} {{ dst_dataset | safe_path | quote }}

