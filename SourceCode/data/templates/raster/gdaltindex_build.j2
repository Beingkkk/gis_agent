{# @id gdaltindex_build #}
{# @name 栅格影像索引构建 #}
{# @description 使用 gdaltindex 为栅格文件创建矢量瓦片索引，生成包含影像范围几何的矢量数据集 #}
{# @concept "gdaltindex 为栅格数据集创建边界矩形索引，输出为包含多边形几何的矢量文件，每个要素对应一个栅格文件" #}
{# @concept "生成的瓦片索引适用于 MapServer 地图服务或 Global Tiled Imagery (GTI) 驱动，可加速大规模影像数据的读取" #}
{# @note 输出默认从文件扩展名推断格式，常见格式包括 GeoJSON、Shapefile、GML 等 #}
{# @note 使用 -t_srs 可统一不同投影的栅格索引到同一坐标系，便于叠加分析 #}
{# @seealso ogr2ogr_convert #}
{# @seealso gdalwarp_reproject #}
{# @common_error "Failed to open datasource" — 指定的索引输出文件路径无效或目录不存在，无法创建输出数据源 #}
{# @common_error "File not recognized as a supported format" — 输入的栅格文件格式不受 GDAL 支持，或文件已损坏无法读取 #}
{# @param index_file file_path required 输出瓦片索引文件路径，将生成包含边界几何的矢量数据集 #}
{# @param file_or_dir file_path required 输入栅格文件路径或包含栅格文件的目录路径 #}
{# @param of string optional 输出瓦片索引的矢量格式，如 GeoJSON、ESRI Shapefile 等，默认从扩展名推断 #}
{# @param tileindex string optional 存储栅格文件路径的字段名称，默认值为 location #}
{# @param t_srs crs optional 目标空间参考系统，索引几何将转换到该坐标系 #}
{# @param overwrite boolean optional 如果索引文件已存在则覆盖 #}
{# @param recursive boolean optional 递归遍历输入目录中的所有子目录 #}
{# @param filename_filter string optional 文件名过滤模式，支持 '*' 和 '?' 通配符，如 '*.tif' #}
{# @param write_absolute_path boolean optional 在索引中存储栅格文件的绝对路径 #}
{# @param skip_different_projection boolean optional 只索引与已存在索引文件投影相同的栅格文件 #}
{# @param src_srs_name string optional 存储每个栅格文件 SRS 的字段名称 #}
{# @param src_srs_format string optional SRS 存储格式，可选 AUTO、WKT、EPSG、PROJ default=AUTO #}
{# @param quiet boolean optional 静默模式，不输出进度信息 #}

@echo off
REM Generated by GIS Agent
REM Template: gdaltindex_build

gdaltindex{% if overwrite %} -overwrite{% endif %}{% if recursive %} -recursive{% endif %}{% if of %} -of {{ of | quote }}{% endif %}{% if tileindex %} -tileindex {{ tileindex | quote }}{% endif %}{% if t_srs %} -t_srs {{ t_srs | quote }}{% endif %}{% if write_absolute_path %} -write_absolute_path{% endif %}{% if skip_different_projection %} -skip_different_projection{% endif %}{% if filename_filter %} -filename_filter {{ filename_filter | quote }}{% endif %}{% if src_srs_name %} -src_srs_name {{ src_srs_name | quote }}{% endif %}{% if src_srs_format %} -src_srs_format {{ src_srs_format | quote }}{% endif %}{% if quiet %} --quiet{% endif %} {{ index_file | safe_path | quote }} {{ file_or_dir | safe_path | quote }}

REM Done
