{# @id gdal_edit_inplace_edit #}
{# @name 原地编辑栅格元数据 #}
{# @description 原地编辑栅格数据集的投影信息、仿射变换、nodata值和元数据 #}
{# @concept "gdal_edit 是 GDAL 的原地栅格编辑工具，可直接修改 GeoTIFF 等支持更新访问的栅格文件的元数据、坐标系和几何校正信息" #}
{# @concept "编辑后的旧值可能在文件中残留（称为 "ghost" 状态），例如 GTiff 格式，这不影响 GDAL API 的正常访问" #}
{# @note gdal_edit 是 Python 工具，需要 GDAL Python 绑定才能使用 #}
{# @note 使用 -ro 参数可以避免某些驱动拒绝更新模式的情况，更新信息会写入 PAM .aux.xml 文件 #}
{# @seealso gdalinfo_dataset_info #}
{# @seealso gdalbuildvrt_combine #}
{# @seealso gdalwarp_reproject #}
{# @common_error "Permission denied / Cannot open" — 栅格文件格式不支持更新访问（如某些压缩格式或只读格式），或文件权限不足 #}
{# @common_error "Unable to open existing dataset" — 指定的栅格数据集不存在，或路径错误 #}
{# @param dataset file_path required 要编辑的栅格数据集路径（必须是支持更新访问的格式） #}
{# @param ro boolean optional 以只读模式打开，更新信息将写入 PAM .aux.xml 文件 #}
{# @param a_srs crs optional 为目标数据集定义或覆盖坐标系统（如 EPSG:4326） #}
{# @param a_ullr string optional 分配/覆盖地理参考范围，参数为上左X、上左Y、下右X、下右Y四个坐标值 #}
{# @param a_coord_epoch float optional 设置或覆盖数据集坐标历元（如 2021.3） #}
{# @param nodata float optional 为输出波段指定 nodata 值 #}
{# @param unsetnodata boolean optional 移除现有的 nodata 值 #}
{# @param tr_x float optional 设置目标分辨率 X 值（必须为正值） #}
{# @param tr_y float optional 设置目标分辨率 Y 值（必须为正值） #}
{# @param unsetgt boolean optional 移除地理参考信息 #}
{# @param stats boolean optional 计算并存储波段统计信息 #}
{# @param approx_stats boolean optional 计算并存储近似波段统计信息 #}
{# @param scale float optional 为波段指定缩放值，通常与 offset 配合使用 #}
{# @param offset float optional 为波段指定偏移值，通常与 scale 配合使用 #}
{# @param mo string optional 元数据标签，格式为 KEY=VALUE #}
{# @param lrx string optional (auto-completed) #}
{# @param lry string optional (auto-completed) #}
{# @param ulx string optional (auto-completed) #}
{# @param uly string optional (auto-completed) #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_edit_inplace_edit

gdal_edit{% if ro %} -ro{% endif %}{% if a_srs %} -a_srs {{ a_srs | quote }}{% endif %}{% if a_ullr %} -a_ullr {{ ulx }} {{ uly }} {{ lrx }} {{ lry }}{% endif %}{% if a_coord_epoch %} -a_coord_epoch {{ a_coord_epoch }}{% endif %}{% if nodata is not none %} -a_nodata {{ nodata }}{% endif %}{% if unsetnodata %} -unsetnodata{% endif %}{% if tr_x and tr_y %} -tr {{ tr_x }} {{ tr_y }}{% endif %}{% if unsetgt %} -unsetgt{% endif %}{% if stats %} -stats{% endif %}{% if approx_stats %} -approx_stats{% endif %}{% if scale is not none %} -scale {{ scale }}{% endif %}{% if offset is not none %} -offset {{ offset }}{% endif %}{% if mo %} -mo {{ mo | quote }}{% endif %} {{ dataset | safe_path | quote }}

