{# @id tif2png #}
{# @name GeoTIFF 转 PNG #}
{# @description 将 GeoTIFF 栅格数据转换为 PNG 格式 #}
{# @concept "GeoTIFF" — 带地理空间元数据的 TIFF 格式，可嵌入坐标系和地理范围 #}
{# @concept "PNG" — 无损压缩位图格式，适合截图和小尺寸可视化，但不保留地理坐标 #}
{# @note 转换后的 PNG 不保留地理坐标信息，仅用于可视化 #}
{# @seealso raster/warp_reproject — 如需同时转换坐标系 #}
{# @common_error "Cannot create dataset" — 输出目录不存在或无写入权限 #}
{# @param input file_path required 输入 GeoTIFF 路径 #}
{# @param output file_path required 输出 PNG 路径 #}

@echo off
REM Generated by GIS Agent
REM Template: tif2png

gdal_translate -of PNG {{ input | safe_path | quote }} {{ output | safe_path | quote }}

REM Done
