{# @id gdal_vector_concat #}
{# @name 矢量数据合并 #}
{# @description 使用 gdal vector concat 将多个矢量数据集按指定模式合并，支持按图层名合并、按图层堆叠或合并为单一图层 #}
{# @concept "gdal vector concat 支持三种合并模式：merge-per-layer-name 按图层名合并同名图层（默认）；stack 保留源数据集前缀创建独立图层；single 将所有图层合并为一个图层" #}
{# @concept "合并时默认使用字段并集策略，可通过 field-strategy 改为交集以确保字段一致性；默认使用第一个源的坐标系作为目标CRS" #}
{# @note 当多个输入图层具有相同CRS但不同几何类型时，可能导致合并失败；建议先统一几何类型 #}
{# @note upsert 模式隐含 append 行为，会根据特征唯一标识进行插入或更新操作 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Layer does not exist" — 指定的输入图层在某个数据源中不存在，请使用 --layer 确认图层名称 #}
{# @common_error "CRS mismatch" — 源图层坐标系不一致且无法自动转换，请使用 --input-crs 或 --output-crs 指定坐标系 #}
{# @param inputs file_path required 输入矢量数据集路径（支持多个，输入顺序决定合并优先级） #}
{# @param output file_path required 输出矢量数据集路径 #}
{# @param of string optional 输出格式名称，如 GeoJSON、ESRI Shapefile、GML 等 #}
{# @param mode string optional 合并模式：merge-per-layer-name（同图层名合并）、stack（保留源数据集前缀）、single（合并为单一图层） default=merge-per-layer-name #}
{# @param input_crs crs optional 输入数据集的坐标参考系统定义（如 EPSG:4326） #}
{# @param output_crs crs optional 目标坐标参考系统定义，用于坐标系转换（如 EPSG:3857） #}
{# @param field_strategy string optional 字段策略：union（合并所有字段）或 intersection（仅保留共同字段） default=union #}
{# @param layer string optional 指定输入图层名称（可重复指定多个） #}
{# @param append boolean optional 追加到现有图层（与 upsert 互斥） #}
{# @param upsert boolean optional  Upsert 模式（插入或更新特征，与 append 互斥） #}
{# @param overwrite boolean optional 允许覆盖已存在的输出数据集 #}
{# @param skip_errors boolean optional 写入时跳过错误继续处理 #}
{# @param source_layer_field_name string optional 添加新字段名以标识要素来源图层 #}

