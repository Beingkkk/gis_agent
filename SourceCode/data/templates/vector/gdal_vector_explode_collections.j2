{# @id gdal_vector_explode_collections #}
{# @name 展开集合几何 #}
{# @description 将矢量数据中的集合几何类型（MULTIPOINT、GEOMETRYCOLLECTION等）展开为独立的单要素 #}
{# @concept "集合几何类型（MULTIPOINT、MULTILINESTRING、MULTIPOLYGON、GEOMETRYCOLLECTION）包含多个几何部分，explode-collections 将每个部分拆分为独立的要素" #}
{# @concept "展开操作是非递归的，例如 GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(POINT(1 2), POINT(3 4))) 只会展开一层，保留内层的 GEOMETRYCOLLECTION" #}
{# @note 该工具可用于 gdal vector pipeline 工作流中的中间处理步骤 #}
{# @note 展开后的几何类型会从多部分变为对应的单部分类型（如 MULTIPOINT 变为多个 POINT） #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Unable to open datasource" — 输入文件路径不存在，或指定的格式不受支持 #}
{# @common_error "Layer not found" — 指定的图层名称在数据源中不存在 #}
{# @param input file_path required 输入矢量数据集路径 #}
{# @param output file_path required 输出矢量数据集路径 #}
{# @param of string optional 输出格式名称，如 GeoJSON、ESRI Shapefile、GPKG 等 #}
{# @param layer string optional 输入图层名称（不指定则处理所有图层） #}
{# @param creation_option string optional 数据集创建选项（KEY=VALUE 格式，可重复使用） #}
{# @param output_layer string optional 输出图层名称 #}
{# @param overwrite boolean optional 允许覆盖已存在的输出数据集 #}
{# @param append boolean optional 追加到现有图层 #}
{# @param quiet boolean optional 静默模式，不显示进度条和警告信息 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_explode_collections

gdal vector explode-collections{% if of %} -f {{ of | quote }}{% endif %}{% if layer %} -l {{ layer | quote }}{% endif %}{% if creation_option %} --co {{ creation_option | quote }}{% endif %}{% if output_layer %} --output-layer {{ output_layer | quote }}{% endif %}{% if overwrite %} --overwrite{% endif %}{% if append %} --append{% endif %}{% if quiet %} -q{% endif %} {{ input | safe_path | quote }} {{ output | safe_path | quote }}

