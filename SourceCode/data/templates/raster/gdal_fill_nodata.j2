{# @id gdal_fill_nodata #}
{# @name 栅格空洞填补 #}
{# @description 通过边缘像元插值填充栅格数据中的 NoData 区域 #}
{# @concept "gdal raster fill-nodata 通过从空洞区域边缘的有效像元向内插值来填补栅格中的 NoData 值，适用于修复遥感影像中的云遮挡、数据缺失等问题" #}
{# @concept "该工具支持反距离加权（IDW）和最近邻两种插值策略，并可通过平滑迭代减少插值产生的人工痕迹" #}
{# @note 当 NoData 区域过大（超过 max_distance）时，中心区域可能无法被完全填补 #}
{# @note 可配合掩膜文件限制填补范围，仅对指定区域进行空洞修复 #}
{# @common_error "No band selected" — 指定的波段序号超出有效范围，需检查输入栅格的实际波段数 #}
{# @common_error "Too large nodata area" — NoData 区域过大，超出 max_distance 搜索范围，可尝试增大该参数值 #}
{# @param input file_path required 输入栅格文件路径，包含待填补的 NoData 区域 #}
{# @param output file_path required 输出栅格文件路径，保存填补后的结果 #}
{# @param band integer optional 要处理的波段序号（从1开始的索引） default=1 #}
{# @param max_distance integer optional 插值搜索的最大像元距离 default=100 #}
{# @param smoothing_iterations integer optional 插值后执行的3x3平滑滤波迭代次数，用于减轻人工痕迹 default=0 #}
{# @param mask file_path optional 有效性掩码文件路径（零值为无效，非零为有效） #}
{# @param strategy string optional 插值策略：invdist（反距离加权）或 nearest（最近邻） default=invdist #}
{# @param overwrite boolean optional 允许覆盖已存在的输出文件 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_fill_nodata

gdal raster fill-nodata{% if band %} -b {{ band }}{% endif %}{% if max_distance %} -d {{ max_distance }}{% endif %}{% if smoothing_iterations %} -s {{ smoothing_iterations }}{% endif %}{% if mask %} --mask {{ mask | quote }}{% endif %}{% if strategy %} --strategy {{ strategy | quote }}{% endif %}{% if overwrite %} --overwrite{% endif %} {{ output | safe_path | quote }} {{ input | safe_path | quote }}

REM Done
