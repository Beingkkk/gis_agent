{# @id gdal_vector_convert #}
{# @name GDAL矢量格式转换 #}
{# @description 使用 gdal vector convert 命令在不同矢量格式之间转换数据，支持创建选项和追加模式 #}
{# @concept "gdal vector convert 是 GDAL 3.7+ 引入的新版矢量转换命令，采用子命令结构设计，支持与 ogr2ogr 相似的格式转换功能" #}
{# @concept "Upsert 模式会先尝试匹配现有要素进行更新，若无匹配则插入新要素，适合增量更新场景" #}
{# @note 输出格式可从文件扩展名自动推断，也可通过 --format 显式指定 #}
{# @note --append 和 --upsert 是互斥选项，只能选择其一使用 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Permission denied" — 输出文件或目录无写入权限，或目标文件已被其他程序独占打开 #}
{# @common_error "Layer does not exist" — 指定的输出图层名称不存在，或尝试追加到不存在的图层 #}
{# @param input file_path required 输入矢量数据集路径 #}
{# @param output file_path required 输出矢量数据集路径 #}
{# @param of string optional 输出格式名称，如 GeoJSON、GPKG、ESRI Shapefile 等 #}
{# @param co string optional 数据集创建选项（格式为 KEY=VALUE） #}
{# @param lco string optional 图层创建选项（格式为 KEY=VALUE） #}
{# @param output_layer string optional 输出图层名称，指定目标图层叫什么 #}
{# @param overwrite boolean optional 是否覆盖已存在的输出数据集 #}
{# @param append boolean optional 是否追加到现有图层，与 --upsert 互斥 #}
{# @param upsert boolean optional Upsert 模式（更新或插入），暗含 --append，与 --append 互斥 #}
{# @param skip_errors boolean optional 写入要素时跳过错误，继续处理后续要素 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_convert

gdal vector convert {{ input | safe_path | quote }} {{ output | safe_path | quote }}{% if of %} --format {{ of | quote }}{% endif %}{% if co %} --creation-option {{ co | quote }}{% endif %}{% if lco %} --layer-creation-option {{ lco | quote }}{% endif %}{% if output_layer %} --output-layer {{ output_layer | quote }}{% endif %}{% if overwrite %} --overwrite{% endif %}{% if append %} --append{% endif %}{% if upsert %} --upsert{% endif %}{% if skip_errors %} --skip-errors{% endif %}

REM Done
