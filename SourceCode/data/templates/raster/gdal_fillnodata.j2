{# @id gdal_fillnodata #}
{# @name 栅格空洞填补 #}
{# @description 使用插值算法填充栅格数据中的空洞（NoData）区域 #}
{# @concept "gdal_fillnodata 通过分析空洞区域边缘的有效像素值，使用插值算法（默认反距离权重法）来计算并填充 NoData 区域" #}
{# @concept "该工具仅处理单个波段，max_distance 参数控制插值搜索范围，过大的值可能导致填充区域与周围纹理不协调" #}
{# @note 这是 GDAL 的 Python 工具脚本，需要 GDAL Python 绑定支持才能运行 #}
{# @note GDAL 3.9 及更新版本推荐使用新的 gdal raster fill-nodata 命令，功能相同但接口更统一 #}
{# @common_error "Unable to open datasource" — 输入的栅格文件路径不存在或文件格式不被 GDAL 支持 #}
{# @common_error "Too much memory consumed" — max_distance 参数设置过大导致内存不足，建议减小该值或分块处理 #}
{# @param src_file file_path required 输入栅格文件路径，包含需要填充的空洞或NoData区域 #}
{# @param dst_file file_path required 输出栅格文件路径，保存填充空洞后的结果 #}
{# @param max_distance integer optional 插值搜索的最大距离（像素单位），默认100像素 default=100 #}
{# @param smoothing_iterations integer optional 3x3平滑滤波迭代次数，用于减少插值产生的纹理瑕疵，默认不执行 #}
{# @param interp string optional 插值方法：inv_dist（反距离权重，默认）或 nearest（最近邻） #}
{# @param band integer optional 要操作的波段编号，默认处理第一个波段 default=1 #}
{# @param mask file_path optional 指定掩码文件，零值区域视为无效，非零区域视为有效 #}
{# @param of string optional 输出格式简称，如 GTiff（GeoTIFF）、HFA 等 #}
{# @param quiet boolean optional 静默模式，抑制进度信息和常规消息输出 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_fillnodata

gdal_fillnodata{% if quiet %} -q{% endif %}{% if max_distance %} -md {{ max_distance }}{% endif %}{% if smoothing_iterations %} -si {{ smoothing_iterations }}{% endif %}{% if interp %} -interp {{ interp | quote }}{% endif %}{% if band %} -b {{ band }}{% endif %}{% if mask %} -mask {{ mask | safe_path | quote }}{% endif %}{% if of %} -of {{ of | quote }}{% endif %} {{ src_file | safe_path | quote }} {{ dst_file | safe_path | quote }}

REM Done
