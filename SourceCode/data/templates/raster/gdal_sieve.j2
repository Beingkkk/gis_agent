{# @id gdal_sieve #}
{# @name 栅格碎多边形消除 #}
{# @description 移除栅格中面积小于指定阈值的细小斑块，用相邻最大斑块的值替代 #}
{# @concept "gdal_sieve 通过识别栅格中面积小于阈值的孤立小斑块，并将其合并到周围面积最大的相邻斑块中，从而消除栅格数据中的噪声碎斑" #}
{# @concept "邻域连接方式决定了判断斑块相邻关系的范围：8邻域包含对角线像元，4邻域仅包含上下左右四个方向的像元" #}
{# @note 输入栅格数据会被当作整数处理，浮点型数据的值会被四舍五入为整数，可能需要先对数据进行重缩放 #}
{# @note gdal_sieve 是 Python 工具，需要 GDAL Python 绑定支持才能使用 #}
{# @seealso gdal_polygonize #}
{# @common_error "RoundFltToInt: Could not convert value" — 输入数据为浮点型且包含非整数值时，工具无法正确处理，需要先将数据转换为整数类型或进行重缩放 #}
{# @common_error "does not have directly accessible pixel values" — 某些压缩格式或只读格式的栅格无法直接读写像素值，可能需要先转换为无压缩格式 #}
{# @param input file_path required 输入栅格文件路径（源文件） #}
{# @param threshold integer required 斑块消除阈值，单位为像素个数，面积小于该阈值的斑块将被消除 #}
{# @param output file_path optional 输出栅格文件路径，如不指定则直接修改原文件 #}
{# @param connectivity string optional 邻域连接方式，-8表示8邻域（对角线），-4表示4邻域（上下左右） default=-8 #}
{# @param mask file_path optional 使用指定文件作为掩膜，掩膜范围内的像元不参与消除计算 #}
{# @param of string optional 输出栅格格式，如 GTiff、GRIBDao 等，默认从扩展名推断 #}
{# @param o string optional 指定算法输出选项，格式为 name=value，用于调试或性能分析 #}
{# @param quiet boolean optional 静默模式，不输出进度信息和警告 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_sieve

gdal_sieve{% if threshold %} -st {{ threshold }}{% endif %}{% if connectivity %} {{ connectivity }}{% endif %}{% if mask %} -mask {{ mask | safe_path | quote }}{% endif %}{% if of %} -of {{ of | quote }}{% endif %}{% if o %} -o {{ o | quote }}{% endif %}{% if quiet %} -q{% endif %}{{ input | safe_path | quote }}{% if output %} {{ output | safe_path | quote }}{% endif %}

REM Done
