{# @id merge_shp #}
{# @name 合并 Shapefile #}
{# @description 将多个 Shapefile 合并为一个文件 #}
{# @param input file_path required 输入主 Shapefile 路径 #}
{# @param append file_path required 待追加的 Shapefile 路径 #}
{# @param output file_path required 输出合并后的路径 #}

@echo off
REM Generated by GIS Agent
REM Template: merge_shp

copy {{ input | safe_path | quote }} {{ output | safe_path | quote }}
ogr2ogr -f "ESRI Shapefile" -update -append {{ output | safe_path | quote }} {{ append | safe_path | quote }}

REM Done
