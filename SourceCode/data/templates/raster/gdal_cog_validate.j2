{# @id gdal_cog_validate #}
{# @name COG 文件验证 #}
{# @description 验证 GeoTIFF 文件是否符合云优化 GeoTIFF (COG) 格式标准并生成验证报告 #}
{# @concept "Cloud Optimized GeoTIFF (COG) 是一种专为云端访问优化的 TIFF 格式，通过 GeoTIFF 扩展和 HTTP Range 请求支持实现高效的云上访问" #}
{# @concept "COG 验证工具会检查文件的内部结构是否符合 COG 规范，包括 GeoTIFF 标签、压缩方式、像素组织结构等" #}
{# @note 该工具需要 GDAL Python 绑定才能正常运行 #}
{# @note full-check 参数设为 auto 时，工具会自动判断是否需要完整检查，设为 yes 则强制执行全部检查项目 #}
{# @common_error "ERROR 1: Unable to open datasource" — 指定的文件不存在或文件格式无法被 GDAL 识别 #}
{# @common_error "Not a COG file" — 该 TIFF 文件不符合云优化 GeoTIFF 标准，常见原因包括未使用合适的压缩算法或缺少必要的 GeoTIFF 标签 #}
{# @param input file_path required 待验证的 COG 数据集文件路径 #}
{# @param full_check string optional 是否执行完整验证检查，可选值: auto|yes|no (默认为 auto) default=auto #}
{# @param quiet boolean optional 静默模式，不显示进度条和警告信息 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_cog_validate

gdal driver cog validate{% if full_check %} --full-check {{ full_check | quote }}{% endif %}{% if quiet %} -q{% endif %} {{ input | safe_path | quote }}

REM Done
