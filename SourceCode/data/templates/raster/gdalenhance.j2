{# @id gdalenhance #}
{# @name 图像对比度增强 #}
{# @description 使用直方图均衡化技术增强栅格图像的对比度 #}
{# @concept "gdalenhance是GDAL的栅格图像增强工具，通过直方图均衡化技术改善图像的对比度和视觉效果" #}
{# @concept "LUT（查找表）是一种像素值映射机制，将原始像素值通过映射函数转换为新值，从而实现对比度调整" #}
{# @note 默认输出格式为GeoTIFF，VRT输出不受支持 #}
{# @note -equalize会计算直方图并自动生成最优LUT，-config则使用用户提供的LUT文件 #}
{# @seealso gdal_contrast_enhance #}
{# @common_error "Unable to open source dataset" — 输入的栅格文件路径不存在或文件格式无法识别 #}
{# @common_error "band count mismatch" — LUT文件的行数与图像波段数不匹配，每个波段需要有独立的LUT映射序列 #}
{# @param src_raster file_path required 输入栅格图像文件路径（源数据集） #}
{# @param dst_raster file_path optional 输出栅格图像文件路径（目标数据集），不指定则自动命名 #}
{# @param of string optional 输出格式，默认GeoTIFF，VRT格式不支持 #}
{# @param co string optional 格式创建选项，用于控制压缩、分块等参数，格式为NAME=VALUE #}
{# @param ot string optional 输出数据类型，如Byte、Int16、UInt16、Float32等 #}
{# @param equalize boolean optional 计算源图像直方图并生成均衡化的LUT表以增强对比度 #}
{# @param config file_path optional 指定预先定义的LUT查找表文件路径来增强对比度 #}

@echo off
REM Generated by GIS Agent
REM Template: gdalenhance

gdalenhance{% if of %} -of {{ of | quote }}{% endif %}{% if co %} -co {{ co | quote }}{% endif %}{% if ot %} -ot {{ ot | quote }}{% endif %}{% if equalize %} -equalize{% endif %}{% if config %} -config {{ config | quote }}{% endif %} {{ src_raster | safe_path | quote }}{% if dst_raster %} {{ dst_raster | safe_path | quote }}{% endif %}

