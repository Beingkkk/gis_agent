{# @id gpkg_validate #}
{# @name GeoPackage 规范验证 #}
{# @description 验证 GeoPackage 数据集是否符合 GeoPackage 规范标准 #}
{# @concept "GeoPackage 是基于 SQLite 的开放地理空间数据容器标准，支持矢量、栅格和瓦片数据" #}
{# @concept "该工具检查数据集是否满足 OGC GeoPackage 规范中的必选和可选要求" #}
{# @note 此工具需要 GDAL Python 绑定可用才能运行 #}
{# @note 完整检查会验证表结构、空间参考、扩展名支持等多个方面 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "GDAL Python bindings are not available" — 系统未安装 GDAL Python 绑定，请先通过 pip install gdal 或系统包管理器安装 #}
{# @common_error "file is not a valid GeoPackage" — 指定的文件不是有效的 GeoPackage 格式，可能已损坏或不是标准的 GeoPackage 数据库 #}
{# @param dataset file_path required 待验证的 GeoPackage 文件路径（.gpkg） #}
{# @param full_check boolean optional 是否执行完整检查（包含完整性、约束、索引等全面验证） #}
{# @param verbose boolean optional 是否启用详细输出模式，显示更多验证信息 #}
{# @param quiet boolean optional 静默模式，不显示进度条和警告信息 #}

@echo off
REM Generated by GIS Agent
REM Template: gpkg_validate

gdal driver gpkg validate{% if full_check %} --full-check{% endif %}{% if verbose %} -v{% endif %}{% if quiet %} -q{% endif %} {{ dataset | safe_path | quote }}

REM Done
