gdal vector check-geometry{% if input_layer %} -l {{ input_layer | quote }}{% endif %}{% if output_format %} -f {{ output_format | quote }}{% endif %}{% if output_layer %} --output-layer {{ output_layer | quote }}{% endif %}{% if include_field %} --include-field {{ include_field | quote }}{% endif %}{% if include_valid %} --include-valid{% endif %}{% if geometry_field %} --geometry-field {{ geometry_field | quote }}{% endif %}{% if skip_errors %} --skip-errors{% endif %}{% if overwrite %} --overwrite{% endif %}{% if append %} --append{% endif %} {{ input | safe_path | quote }} {{ output | safe_path | quote }}

