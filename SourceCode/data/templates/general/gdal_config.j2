{# @id gdal_config #}
{# @name GDAL 安装信息查询 #}
{# @description 查询 GDAL 库的编译配置信息，包括版本号、安装路径和驱动支持情况 #}
{# @concept "gdal-config 是一个 Unix 系统下的 GDAL 配置查询脚本，主要供编译时使用，也可用于查询 GDAL 安装环境信息" #}
{# @concept "通过该工具可快速获取 GDAL 的安装路径、版本信息及支持的栅格和矢量数据格式列表" #}
{# @note 该工具仅在 Unix/Linux 系统下可用，Windows 系统需使用其他方式查询 GDAL 配置 #}
{# @note 实际使用时通常只查询部分信息，如查看版本用 --version，查看支持的格式用 --formats #}
{# @common_error "gdal-config: command not found" — GDAL 未正确安装或未将安装目录添加到系统 PATH 环境变量中 #}
{# @common_error "No such file or directory" — 指定的 --prefix 路径不存在或 GDAL 安装目录结构异常 #}
{# @param prefix boolean optional 查询 GDAL 的安装根目录路径 #}
{# @param prefix_dir string optional 指定 GDAL 安装根目录（与 --prefix 配合使用） #}
{# @param libs boolean optional 输出 GDAL 库及链接参数信息 #}
{# @param cflags boolean optional 输出编译 GDAL 模块所需的头文件和宏定义 #}
{# @param version boolean optional 显示 GDAL 版本号 #}
{# @param ogr_enabled boolean optional 检查 GDAL 是否包含 OGR 矢量支持 #}
{# @param formats boolean optional 列出 GDAL 已配置支持的所有格式驱动 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_config

gdal-config{% if prefix %} --prefix{% if prefix_dir %}={{ prefix_dir | quote }}{% endif %}{% endif %}{% if libs %} --libs{% endif %}{% if cflags %} --cflags{% endif %}{% if version %} --version{% endif %}{% if ogr_enabled %} --ogr-enabled{% endif %}{% if formats %} --formats{% endif %}

REM Done
