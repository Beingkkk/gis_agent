{# @id gdalcompare #}
{# @name 栅格数据集比对 #}
{# @description 比较两个GDAL数据集的像素、元数据和投影信息差异 #}
{# @concept "gdalcompare是GDAL Python工具，通过比较两个栅格数据集的像素值、元数据、投影信息等判断两者是否一致" #}
{# @concept "工具返回差异计数（exit value），如果差异计数仅为1（仅二进制差异），说明GDAL可视数据完全相同" #}
{# @note 返回的差异计数包含多个维度的差异累加，如元数据、投影、像素值等 #}
{# @note 可配合多个跳过选项进行针对性比较，例如只想比较像素值差异时可跳过元数据比较 #}
{# @common_error "Unable to open datasource" — 指定的参考文件或新文件路径不存在，或文件格式GDAL不支持 #}
{# @common_error "difference count: 0" — 表示两个数据集完全一致，包括二进制内容 #}
{# @param golden_file file_path required 作为基准的参考文件（正确的数据集） #}
{# @param new_file file_path required 待比较的新文件 #}
{# @param dumpdiffs boolean optional 是否将像素差异内容输出为TIFF文件保存 #}
{# @param skip_binary boolean optional 是否跳过二进制内容的精确比较 #}
{# @param skip_overviews boolean optional 是否跳过概视图（Overviews）的比较 #}
{# @param skip_geolocation boolean optional 是否跳过GEOLOCATION元数据域的比较 #}
{# @param skip_geotransform boolean optional 是否跳过地理变换矩阵的比较 #}
{# @param skip_metadata boolean optional 是否跳过元数据的比较 #}
{# @param skip_rpc boolean optional 是否跳过RPC（有理多项式系数）元数据域的比较 #}
{# @param skip_srs boolean optional 是否跳过空间参考系统的比较 #}
{# @param sds boolean optional 是否比较所有子数据集，默认只比较主数据集 #}

