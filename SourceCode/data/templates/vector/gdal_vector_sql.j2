{# @id gdal_vector_sql #}
{# @name 矢量数据SQL查询 #}
{# @description 使用 SQL 语句对矢量数据进行查询、更新、删除等操作 #}
{# @concept "gdal vector sql 是 GDAL 3.7+ 提供的矢量数据 SQL 执行工具，支持直接在矢量数据集上执行 SELECT、UPDATE、DELETE 等 SQL 操作" #}
{# @concept "支持多种 SQL 方言，其中 SQLITE 方言支持更丰富的函数和聚合操作，OGRSQL 是 GDAL 原生方言" #}
{# @note 使用 --update 模式且不指定输出时，可直接修改输入数据集（GDAL 3.12+ 支持 UPDATE、DELETE 等写操作） #}
{# @note 可通过 --sql 参数多次指定执行多条 SQL 语句，或使用 @filename 语法从外部文件读取 SQL 脚本 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "SQL Error" — SQL 语法错误，或使用的方言不支持该语句，检查 dialect 参数是否正确 #}
{# @common_error "Unable to open datasource" — 输入文件路径不存在，或文件格式不受 GDAL 支持 #}
{# @param input file_path required 输入矢量数据集路径 #}
{# @param sql string required 要执行的 SQL 语句（支持 @filename 从文件读取） #}
{# @param output file_path optional 输出矢量数据集路径，不指定则在内存中执行 #}
{# @param dialect string optional SQL 方言（如 OGRSQL、SQLITE、INDIRECT_SQL） #}
{# @param of string optional 输出格式名称（如 GeoJSON、ESRI Shapefile 等） #}
{# @param output_layer string optional 输出图层名称 #}
{# @param update boolean optional 以更新模式打开数据集，允许执行 UPDATE、DELETE 等修改操作 #}
{# @param append boolean optional 追加到现有图层 #}
{# @param overwrite boolean optional 允许覆盖已存在的输出数据集 #}
{# @param skip_errors boolean optional 写入要素时跳过错误继续执行 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_sql

gdal vector sql{% if sql %} --sql {{ sql | quote }}{% endif %}{% if dialect %} --dialect {{ dialect | quote }}{% endif %}{% if output %} -o {{ output | safe_path | quote }}{% endif %}{% if of %} -f {{ of | quote }}{% endif %}{% if output_layer %} --output-layer {{ output_layer | quote }}{% endif %}{% if append %} --append{% endif %}{% if update %} --update{% endif %}{% if overwrite %} --overwrite{% endif %}{% if skip_errors %} --skip-errors{% endif %} {{ input | safe_path | quote }}

REM Done
