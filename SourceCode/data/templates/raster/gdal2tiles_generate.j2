{# @id gdal2tiles_generate #}
{# @name 生成Web地图瓦片 #}
{# @description 将栅格影像生成为符合OSGeo瓦片地图服务规范的Web地图瓦片，支持多种在线地图查看器 #}
{# @concept "gdal2tiles 按 OSGeo Tile Map Service 规范生成金字塔式瓦片结构，自动创建可在浏览器中查看的 Web 地图页面" #}
{# @concept "默认使用墨卡托投影（mercator）生成的瓦片与谷歌地图、必应地图等主流在线地图服务兼容" #}
{# @note 自 GDAL 3.13 起，gdal2tiles 已迁移至 gdal raster tile 命令，建议使用新版工具 #}
{# @note 对于 Int16、UInt16 等非字节类型数据会强制转换为字节类型，建议先用 gdal_translate 转为 Byte 类型以避免数据失真 #}
{# @seealso gdal_translate_convert #}
{# @seealso gdalinfo_info #}
{# @common_error "Zoom level out of range" — 输入影像的分辨率无法支持指定的缩放级别，需检查影像的像素尺寸和地理范围是否匹配目标缩放级别 #}
{# @common_error "Unable to open datasource" — 输入文件格式不受支持或文件损坏，需确认 GDAL 已支持该栅格格式 #}
{# @param input file_path required 输入栅格文件路径（支持 GeoTIFF、ECW、MrSID 等格式） #}
{# @param output file_path optional 输出瓦片目录路径，默认为当前目录下的同名文件夹 #}
{# @param profile string optional 瓦片切割方案，可选 mercator（谷歌地图兼容）、geodetic（经纬度）、raster（直接投影） default=mercator #}
{# @param zoom string optional 缩放级别范围，格式为起始-结束（如 2-5） #}
{# @param srs crs optional 源数据的空间参考系统（如 EPSG:4326、EPSG:3857） #}
{# @param resampling string optional 重采样方法，可选 average、near、bilinear、cubic、cubicspline、lanczos、mode 等 default=average #}
{# @param webviewer string optional 生成的网页查看器类型，可选 googlemaps、openlayers、leaflet、all default=all #}
{# @param xyz boolean optional 生成XYZ格式瓦片（OSM标准）而非TMS格式 #}
{# @param title string optional 生成的网页地图标题 #}
{# @param processes integer optional 并行处理使用的进程数量 #}
{# @param ndv float optional 指定无效值/背景值 #}
{# @param copyright string optional (auto-completed) #}
{# @param tilesize string optional (auto-completed) #}
{# @param url string optional (auto-completed) #}

@echo off
REM Generated by GIS Agent
REM Template: gdal2tiles_generate

gdal2tiles{% if profile %} -p {{ profile | quote }}{% endif %}{% if zoom %} -z {{ zoom | quote }}{% endif %}{% if srs %} -s {{ srs | quote }}{% endif %}{% if resampling %} -r {{ resampling | quote }}{% endif %}{% if webviewer %} -w {{ webviewer | quote }}{% endif %}{% if title %} -t {{ title | quote }}{% endif %}{% if copyright %} -c {{ copyright | quote }}{% endif %}{% if xyz %} --xyz{% endif %}{% if processes %} --processes={{ processes }}{% endif %}{% if tilesize %} --tilesize={{ tilesize }}{% endif %}{% if url %} -u {{ url | quote }}{% endif %}{% if ndv %} -a {{ ndv }}{% endif %} {{ input | safe_path | quote }}{% if output %} {{ output | safe_path | quote }}{% endif %}

REM Done
