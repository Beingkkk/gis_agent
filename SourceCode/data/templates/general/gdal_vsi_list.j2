{# @id gdal_vsi_list #}
{# @name 列出虚拟文件系统文件 #}
{# @description 列出 GDAL 虚拟文件系统中的文件和目录，支持递归遍历和多种输出格式 #}
{# @concept "GDAL 虚拟文件系统（VSI）提供了统一的接口访问各种存储介质，包括内存(/vsimem)、ZIP压缩文件(/vsizip)、tar归档(/vsitar)、远程HTTP资源(/vsicurl)等" #}
{# @concept "gdal vsi list 等同于 UNIX 的 ls 命令，但可以操作虚拟文件系统中的文件" #}
{# @note 默认以 JSON 格式输出，输出内容为文件列表 #}
{# @note depth 参数仅在启用 recursive 模式时生效 #}
{# @common_error "Unable to open" — 指定的路径不存在或无法访问，检查 VSI 路径格式是否正确 #}
{# @common_error "Invalid depth value" — depth 参数值无效，必须为正整数 #}
{# @param filename file_path required 要列出的文件或目录路径（支持 VSI 虚拟文件系统路径） #}
{# @param output_format string optional 输出格式，支持 json 或 text 格式 default=json #}
{# @param recursive boolean optional 递归列出子目录中的文件 #}
{# @param depth integer optional 递归模式下的最大遍历深度 #}
{# @param long_listing boolean optional 使用详细列表格式，显示文件大小、修改时间等信息 #}
{# @param absolute_path boolean optional 显示文件的绝对路径 #}
{# @param tree boolean optional 以层级树状结构展示 JSON 输出 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vsi_list

gdal vsi list{% if recursive %} -R{% endif %}{% if depth %} --depth {{ depth }}{% endif %}{% if output_format %} -f {{ output_format | quote }}{% endif %}{% if long_listing %} -l{% endif %}{% if absolute_path %} --abs{% endif %}{% if tree %} --tree{% endif %} {{ filename | safe_path | quote }}

REM Done
