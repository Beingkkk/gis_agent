{# @id gdal_dataset_delete #}
{# @name 删除栅格数据集 #}
{# @description 使用 gdal dataset delete 命令删除指定的栅格数据集文件或目录 #}
{# @concept "gdal dataset delete 是 GDAL 3.7+ 版本提供的官方数据集删除命令，用于删除栅格数据集文件或目录" #}
{# @concept "与操作系统 rm 命令不同，该命令会识别 GDAL 支持的栅格格式，确保正确清理关联的辅助文件" #}
{# @note 支持通过重复指定 --filename 参数一次性删除多个数据集 #}
{# @note 删除目录时会移除整个目录及其包含的所有栅格文件 #}
{# @common_error "Unable to delete dataset" — 文件路径不存在，或当前用户对该文件/目录没有写权限 #}
{# @common_error "Unsupported format" — 指定的文件格式不被 GDAL 支持，或文件已损坏无法被正确识别 #}
{# @param filename file_path required 要删除的文件或目录路径（支持重复指定多个） #}
{# @param format string optional 数据集格式（用于识别文件类型） #}
{# @param config string optional GDAL 配置选项，格式为 KEY=VALUE（如 --config CPL_DEBUG ON） #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_dataset_delete

gdal dataset delete{% if format %} -f {{ format | quote }}{% endif %}{% if config %} --config {{ config | quote }}{% endif %} --filename {{ filename | safe_path | quote }}

REM Done
