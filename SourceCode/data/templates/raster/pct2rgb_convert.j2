{# @id pct2rgb_convert #}
{# @name 伪彩色波段转RGB #}
{# @description 将栅格数据的伪彩色波段或颜色表转换为RGB/RGBA格式输出 #}
{# @concept "伪彩色波段是栅格数据中通过颜色表（调色板）映射存储的波段，每个像素值对应一个RGB颜色" #}
{# @concept "pct2rgb 将颜色表展开为独立的红、绿、蓝三个波段，生成标准RGB栅格图像" #}
{# @note pct2rgb 是 Python 工具，需要 GDAL Python 绑定支持才能运行 #}
{# @note gdal_translate 的 -expand rgb|rgba 选项功能与此工具相同，且更为现代，建议优先使用 #}
{# @seealso gdal_translate_convert #}
{# @common_error "MissingColorTable" — 输入栅格文件没有颜色表，无法进行伪彩色到RGB的转换 #}
{# @common_error "Error: band number out of range" — 指定的波段编号超出有效范围，应使用1到总波段数之间的数值 #}
{# @param source_file file_path required 输入的栅格文件路径（包含伪彩色波段或颜色表） #}
{# @param dest_file file_path required 输出RGB/RGBA文件路径 #}
{# @param of string optional 输出格式名称，如 GTiff、PNG 等，默认从扩展名推断 #}
{# @param b string optional 要转换的波段编号，默认值为1 #}
{# @param rgba boolean optional 输出RGBA四通道文件（默认输出RGB三通道） #}
{# @param pct file_path optional 颜色表文件路径，用于统一多个文件的颜色映射 #}

@echo off
REM Generated by GIS Agent
REM Template: pct2rgb_convert

pct2rgb{% if of %} -of {{ of | quote }}{% endif %}{% if b %} -b {{ b | quote }}{% endif %}{% if rgba %} -rgba{% endif %}{% if pct %} -pct {{ pct | safe_path | quote }}{% endif %} {{ source_file | safe_path | quote }} {{ dest_file | safe_path | quote }}

REM Done
