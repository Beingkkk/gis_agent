{# @id ogrtindex_tile_index #}
{# @name 创建矢量切片索引 #}
{# @description 使用 ogrtindex 创建矢量文件的切片索引，记录多个源文件的空间范围和标识信息 #}
{# @concept "切片索引（Tile Index）是一个包含多个文件标识和空间范围的矢量文件，主要用于 MapServer 等 GIS 服务器的瓦片化访问" #}
{# @concept "ogrtindex 自动生成矩形多边形表示每个源文件的边界范围，并存储文件路径信息" #}
{# @note 默认情况下会为每个源文件的所有图层创建独立的索引记录 #}
{# @note 如果索引文件已存在，新记录会追加到现有文件中而非覆盖 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Unable to open datasource" — 源文件路径不存在、文件格式不支持或损坏 #}
{# @common_error "Layer does not exist" — 指定的图层编号（-lnum）超出范围，或图层名称（-lname）不存在于源文件中 #}
{# @param output file_path required 输出切片索引文件路径（默认生成 Shapefile 格式） #}
{# @param src_datasets file_path required 一个或多个源矢量文件路径，将被索引到输出切片索引中 #}
{# @param of string optional 输出格式名称，默认创建 Shapefile #}
{# @param tileindex string optional 存储文件路径的字段名称，默认使用 LOCATION default=LOCATION #}
{# @param t_srs crs optional 目标空间参考系统，索引范围将转换到该坐标系 #}
{# @param skip_different_projection boolean optional 仅索引与已有图层投影相同的文件 #}
{# @param write_absolute_path boolean optional 使用绝对路径写入文件路径 #}
{# @param lnum integer optional 从每个源文件添加指定编号（图层从 0 开始）的图层 #}
{# @param lname string optional 从每个源文件添加指定名称的图层 #}
{# @param src_srs_format string optional 空间参考系统的存储格式：自动检测、WKT、EPSG 代码或 PROJ 字符串 #}
{# @param accept_different_schemas boolean optional 允许索引不同属性结构的图层（可能导致与 MapServer 不兼容） #}
{# @param src string optional (auto-completed) #}

@echo off
REM Generated by GIS Agent
REM Template: ogrtindex_tile_index

ogrtindex{% if of %} -f {{ of | quote }}{% endif %}{% if tileindex %} -tileindex {{ tileindex | quote }}{% endif %}{% if t_srs %} -t_srs {{ t_srs | quote }}{% endif %}{% if skip_different_projection %} -skip_different_projection{% endif %}{% if write_absolute_path %} -write_absolute_path{% endif %}{% if lnum %} -lnum {{ lnum }}{% endif %}{% if lname %} -lname {{ lname | quote }}{% endif %}{% if src_srs_format %} -src_srs_format {{ src_srs_format | quote }}{% endif %}{% if accept_different_schemas %} -accept_different_schemas{% endif %} {{ output | safe_path | quote }}{% for src in src_datasets %} {{ src | safe_path | quote }}{% endfor %}

