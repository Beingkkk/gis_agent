{# @id gdal_vector_sort #}
{# @name 矢量数据空间排序 #}
{# @description 对矢量图层中的要素按几何空间位置进行排序，支持 Hilbert 和 STRtree 排序算法 #}
{# @concept "Hilbert 曲线排序算法将空间上相邻的几何要素排列在输出结果的相近位置，有利于空间查询和渲染性能优化" #}
{# @concept "STRtree 排序算法基于空间索引树结构进行排序，使用时需要 GDAL 编译时链接 GEOS 库" #}
{# @note 默认排序方法为 Hilbert 算法，空几何或空值几何会被排列在排序结果的最后 #}
{# @note 该工具可作为 gdal vector pipeline 流程中的一个处理步骤 #}
{# @common_error "Sort-Tile-Recursive (STRTree) method not available" — 当前 GDAL 编译版本未链接 GEOS 库，无法使用 STRtree 排序算法 #}
{# @common_error "Unable to open datasource" — 输入文件路径不存在，或指定的格式不受支持 #}
{# @param input file_path required 输入矢量数据集路径 #}
{# @param output file_path required 输出矢量数据集路径 #}
{# @param layer string optional 输入图层名称 #}
{# @param of string optional 输出格式名称，如 GeoJSON、ESRI Shapefile 等 #}
{# @param method string optional 几何排序算法：hilbert（默认）或 strtree default=hilbert #}
{# @param geometry_field string optional 用于排序的几何字段名称 #}
{# @param overwrite boolean optional 允许覆盖已存在的输出数据集 #}
{# @param append boolean optional 允许追加到现有图层 #}
{# @param overwrite_layer boolean optional 允许覆盖已存在的输出图层 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_sort

gdal vector sort{% if layer %} -l {{ layer | quote }}{% endif %}{% if of %} -f {{ of | quote }}{% endif %}{% if method %} --method {{ method | quote }}{% endif %}{% if geometry_field %} --geometry-field {{ geometry_field | quote }}{% endif %}{% if overwrite %} --overwrite{% endif %}{% if append %} --append{% endif %}{% if overwrite_layer %} --overwrite-layer{% endif %} {{ output | safe_path | quote }} {{ input | safe_path | quote }}

REM Done
