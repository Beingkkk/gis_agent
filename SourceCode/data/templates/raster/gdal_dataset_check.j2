{# @id gdal_dataset_check #}
{# @name 数据集完整性检查 #}
{# @description 使用 gdal dataset check 检查栅格或矢量数据集在读取时是否存在错误 #}
{# @concept "gdal dataset check 是 GDAL 提供的数据集完整性验证工具，通过尝试读取数据集内容来检测潜在错误" #}
{# @concept "该工具支持栅格、矢量及多维栅格等多种数据类型的数据源检查" #}
{# @note 该工具仅执行读取测试，不会修改源数据 #}
{# @note 静默模式下会隐藏所有警告信息，便于在脚本中自动化运行 #}
{# @common_error "Unable to open datasource" — 无法打开数据集，可能是文件路径不存在、文件损坏或格式不支持 #}
{# @common_error "Segmentation fault" — 数据集本身存在读取错误，可尝试使用 --config 或 --open-option 调整读取参数 #}
{# @param input file_path required 输入的栅格、矢量或多维栅格数据集路径 #}
{# @param quiet boolean optional 静默模式，不显示进度条或警告信息 #}
{# @param input_format string optional 指定输入数据的格式（如 GTiff、GPKG 等） #}
{# @param open_option string optional 数据集打开选项，格式为 KEY=VALUE #}
{# @param config string optional GDAL 配置选项，格式为 KEY=VALUE #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_dataset_check

gdal dataset check{% if input_format %} --input-format {{ input_format | quote }}{% endif %}{% if open_option %} --open-option {{ open_option | quote }}{% endif %}{% if config %} --config {{ config | quote }}{% endif %}{% if quiet %} --quiet{% endif %} {{ input | safe_path | quote }}

