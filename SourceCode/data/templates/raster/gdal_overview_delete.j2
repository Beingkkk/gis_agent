{# @id gdal_overview_delete #}
{# @name 栅格概览删除 #}
{# @description 从栅格数据集中删除所有现有的概览金字塔图层 #}
{# @concept "概览（Pyramids/Overviews）是栅格影像的多分辨率降采样表示，用于加速大图层的显示和读取性能" #}
{# @concept "外部概览存储在独立文件中（如 GeoTIFF 的 .ovr 文件），而非嵌入到主数据集中" #}
{# @note 删除概览后，被移除概览所占用的空间通常不会被立即释放，建议后续使用 gdal raster convert 重新创建紧凑的数据集 #}
{# @note 该命令会删除数据集的所有概览图层，操作不可逆，请谨慎使用 #}
{# @seealso gdal_overview_build #}
{# @common_error "不能打开数据集" — 输入的文件路径不存在，或者指定的文件不是有效的栅格格式 #}
{# @common_error "Failed to delete overview file" — 可能由于文件权限问题或概览文件已被手动删除导致 #}
{# @param input file_path required 输入栅格数据集路径（将原地更新，除非使用 --external） #}
{# @param external boolean optional 删除外部概览（存储在单独文件中的概览图层） #}
{# @param quiet boolean optional 静默模式，不显示进度条或警告信息 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_overview_delete

gdal raster overview delete{% if external %} --external{% endif %}{% if quiet %} -q{% endif %} {{ input | safe_path | quote }}

REM Done
