{# @id gdalsrsinfo_srs_info #}
{# @name 空间参考信息查询 #}
{# @description 查询空间参考系统的详细信息，以WKT、PROJ.4等多种格式输出 #}
{# @concept "gdalsrsinfo是GDAL提供的空间参考系统信息查询工具，支持从数据集文件、EPSG编码、WKT、PROJ.4等多种方式定义SRS" #}
{# @concept "输出的SRS信息可用于确认数据坐标系统、配置图层投影或在其他GDAL工具中进行坐标系转换" #}
{# @note srs_def参数既可以是EPSG:4326这样的代码，也可以是完整的WKT字符串或数据集文件路径 #}
{# @note 使用-e选项时，工具会反向查找该SRS对应的EPSG编号，适用于需要确定坐标系统代码的场景 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Unable to open datasource" — 输入的SRS定义格式不正确，或指定的文件路径不存在/不包含有效的坐标系统信息 #}
{# @common_error "PROJ: proj_create: unrecognized format or missing definition" — 提供的SRS定义字符串格式有误，无法被PROJ解析 #}
{# @param srs_def string required 空间参考定义，可为EPSG编码（如EPSG:4326）、WKT字符串、PROJ.4字符串或包含SRS信息的文件路径 #}
{# @param o string optional 输出格式类型，如proj4、wkt、wkt2、PROJJSON等，默认为proj4和wkt #}
{# @param single_line boolean optional 将WKT输出为单行格式（不加此参数则多行输出） #}
{# @param V boolean optional 验证SRS有效性 #}
{# @param e boolean optional 查找与该SRS对应的EPSG编号 #}

@echo off
REM Generated by GIS Agent
REM Template: gdalsrsinfo_srs_info

gdalsrsinfo{% if single_line %} --single-line{% endif %}{% if V %} -V{% endif %}{% if e %} -e{% endif %}{% if o %} -o {{ o | quote }}{% endif %} {{ srs_def | quote }}

REM Done
