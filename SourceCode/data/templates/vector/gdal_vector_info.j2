{# @id gdal_vector_info #}
{# @name 矢量数据集信息查询 #}
{# @description 使用 gdal vector info 查询 GDAL 支持的矢量数据集的元数据、图层信息、要素详情等 #}
{# @concept "gdal vector info 是 GDAL 3.x 引入的新版矢量信息查询工具，可获取数据集的坐标系、图层结构、要素几何与属性等信息" #}
{# @concept "支持输出为 JSON 格式便于程序解析，也支持 SQL 查询、属性过滤等高级操作" #}
{# @note 使用 --features 列出全部要素时，大型数据集可能消耗大量内存，建议配合 --limit 使用 #}
{# @note 输出格式默认为文本，程序调用时推荐使用 -f json 获取结构化输出 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Unable to open datasource" — 输入文件路径不存在或文件格式不被 GDAL 支持 #}
{# @common_error "Layer not found" — 指定的图层名称在数据集中不存在，可用无参数查询获取所有图层名称 #}
{# @param input file_path required 输入矢量数据集路径（支持 shapefile、GeoJSON、PostGIS 等 GDAL 支持的格式） #}
{# @param of string optional 输出格式，可选 json 或 text（默认 text） #}
{# @param layer string optional 指定要查询的图层名称（可重复指定多个图层） #}
{# @param features boolean optional 列出所有要素的详细信息（大数据量时注意内存消耗） #}
{# @param summary boolean optional 仅列出图层名称和几何类型摘要 #}
{# @param limit integer optional 限制每个图层返回的要素数量 #}
{# @param sql string optional 执行 SQL 查询语句并返回结果 #}
{# @param where string optional 属性过滤条件（SQL WHERE 子句的简化形式） #}
{# @param fid integer optional 指定要素的 FeatureID 进行查询 #}
{# @param dialect string optional SQL 方言（如 OGRSQL、SQLITE），影响 SQL 语句的解析方式 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_info

gdal vector info{% if of %} -f {{ of | quote }}{% endif %}{% if layer %} -l {{ layer | quote }}{% endif %}{% if features %} --features{% endif %}{% if summary %} --summary{% endif %}{% if limit %} --limit {{ limit | quote }}{% endif %}{% if sql %} --sql {{ sql | quote }}{% endif %}{% if where %} --where {{ where | quote }}{% endif %}{% if fid %} --fid {{ fid | quote }}{% endif %}{% if dialect %} --dialect {{ dialect | quote }}{% endif %} {{ input | safe_path | quote }}

REM Done
