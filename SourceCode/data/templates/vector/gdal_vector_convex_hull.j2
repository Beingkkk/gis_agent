{# @id gdal_vector_convex_hull #}
{# @name 矢量凸包计算 #}
{# @description 计算矢量数据集中几何要素的最小凸包多边形 #}
{# @concept "凸包（Convex Hull）是包含所有输入点的最小凸多边形，是计算几何中的基础操作" #}
{# @concept "计算结果通常是 Polygon 要素，但对于退化输入（如所有点共线）也可能返回 LineString 或 Point" #}
{# @note 凸包计算可以串接到 gdal vector pipeline 中作为处理步骤使用 #}
{# @note --append 和 --upsert 选项互斥，同时只能使用其中一个 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Unable to open datasource" — 输入文件路径不存在或格式不支持 #}
{# @common_error "Layer not found" — 指定的输入图层名称不存在或拼写错误 #}
{# @param input file_path required 输入矢量数据集路径 #}
{# @param output file_path required 输出矢量数据集路径 #}
{# @param layer string optional 输入图层名称，指定要处理的图层 #}
{# @param of string optional 输出格式名称（如 GeoJSON、GPKG 等） #}
{# @param output_layer string optional 输出图层名称 #}
{# @param active_geometry string optional 指定要处理的几何字段名称 #}
{# @param append boolean optional 追加到现有图层（与 upsert 互斥） #}
{# @param upsert boolean optional 插入或更新要素（隐含 append，与 append 互斥） #}
{# @param overwrite boolean optional 允许覆盖现有输出数据集 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_convex_hull

gdal vector convex-hull{% if layer %} -l {{ layer | quote }}{% endif %}{% if of %} -f {{ of | quote }}{% endif %}{% if output_layer %} --output-layer {{ output_layer | quote }}{% endif %}{% if append %} --append{% endif %}{% if upsert %} --upsert{% endif %}{% if overwrite %} --overwrite{% endif %}{% if active_geometry %} --active-geometry {{ active_geometry | quote }}{% endif %} {{ input | safe_path | quote }} {{ output | safe_path | quote }}

