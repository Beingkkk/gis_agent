{# @id gdal_vsi_delete #}
{# @name 删除VSI虚拟文件系统文件 #}
{# @description 使用 gdal vsi delete 命令删除 GDAL 虚拟文件系统或本地文件系统中的文件和目录 #}
{# @concept "VSI（Virtual System Interface）是 GDAL 的虚拟文件系统接口，支持访问内存文件系统（/vsimem）、压缩包内文件（/vsizip、/vsitar）、网络资源（/vsicurl）等多种虚拟存储" #}
{# @concept "gdal vsi delete 等同于 Unix/Linux 系统中的 rm 命令，支持删除本地文件和 VSI 虚拟文件系统中的资源" #}
{# @note 该命令无法撤销，删除后的文件无法恢复，操作需谨慎 #}
{# @note 支持删除真实文件系统中的文件和 GDAL 支持的各种虚拟文件系统中的资源 #}
{# @common_error "No such file or directory" — 指定的文件或目录路径不存在，或 VSI 路径格式不正确 #}
{# @common_error "Is a directory" — 尝试删除目录但未使用递归模式（-r 参数），需要添加 -r 才能删除非空目录 #}
{# @param filename file_path required 要删除的文件或目录路径（支持 VSI 虚拟路径如 /vsimem、/vsizip、/vsicurl 等） #}
{# @param recursive boolean optional 递归删除目录及其包含的所有文件和子目录 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vsi_delete

gdal vsi delete{% if recursive %} -r{% endif %} {{ filename | quote }}

REM Done
