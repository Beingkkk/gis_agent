{# @id gdal_vector_select #}
{# @name 矢量字段筛选 #}
{# @description 从矢量数据集中选择或排除指定字段，生成只包含所需属性的新数据集 #}
{# @concept "gdal vector select 用于从矢量数据中提取特定字段，相当于 SQL 中的 SELECT column1, column2 FROM" #}
{# @concept "该工具可作为 gdal vector pipeline 的一个步骤使用，实现复杂的数据处理流程" #}
{# @note fields 参数为位置参数，直接跟在输入输出路径之后，与其他选项参数不同 #}
{# @note 使用 --exclude 时，fields 参数指定要排除的字段；不使用时则指定要保留的字段 #}
{# @seealso ogr2ogr_convert #}
{# @common_error "Invalid sqlType" — 指定的字段不存在于输入数据中，请检查字段名称拼写是否正确 #}
{# @common_error "File exists and overwrite flag not set" — 输出文件已存在，需要添加 --overwrite 参数覆盖，或更改输出路径 #}
{# @param input file_path required 输入矢量数据集路径 #}
{# @param output file_path required 输出矢量数据集路径 #}
{# @param fields string required 要选择的字段名称（逗号分隔），或配合 --exclude 排除指定字段 #}
{# @param layer string optional 输入图层名称，指定要处理的具体图层 #}
{# @param of string optional 输出格式名称（如 GeoJSON、GPKG 等） #}
{# @param exclude boolean optional 排除指定字段而非选择，配合 fields 参数使用 #}
{# @param output_layer string optional 输出图层名称 #}
{# @param overwrite boolean optional 允许覆盖已存在的输出数据集 #}
{# @param append boolean optional 允许追加到现有图层（与 upsert 互斥） #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_vector_select

gdal vector select{% if layer %} -l {{ layer | quote }}{% endif %}{% if of %} -f {{ of | quote }}{% endif %}{% if exclude %} --exclude{% endif %}{% if output_layer %} --output-layer {{ output_layer | quote }}{% endif %}{% if overwrite %} --overwrite{% endif %}{% if append %} --append{% endif %} {{ input | safe_path | quote }} {{ output | safe_path | quote }} {{ fields | quote }}

REM Done
