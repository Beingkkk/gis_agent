{# @id gdal_gpkg_repack #}
{# @name GeoPackage数据库整理 #}
{# @description 对GeoPackage数据执行VACUUM操作以回收因更新或删除造成的空间浪费 #}
{# @concept "GeoPackage是基于SQLite的地理空间数据容器，repacks命令执行SQLite的VACUUM操作来重建数据库文件并回收碎片空间" #}
{# @concept "此操作会修改原始文件，属于原地（in-place）操作，适用于GeoPackage中的矢量图层和 raster tiles" #}
{# @note 操作过程中可能需要较大的临时空间，建议在磁盘空间充足时执行 #}
{# @note 对于正在被其他应用访问的GeoPackage文件，repack操作可能会失败 #}
{# @common_error "SQLite error: database is locked" — GeoPackage文件正被其他应用程序或进程占用，无法执行VACUUM操作 #}
{# @common_error "SQLite error: database disk image is malformed" — GeoPackage文件已损坏，可能需要先进行数据备份和修复 #}
{# @param dataset file_path required 要整理的GeoPackage数据库文件路径 #}
{# @param config string optional GDAL配置选项，格式为 KEY=VALUE，可重复使用 #}

@echo off
REM Generated by GIS Agent
REM Template: gdal_gpkg_repack

gdal driver gpkg repack{% if config %} --config {{ config | quote }}{% endif %} {{ dataset | safe_path | quote }}

